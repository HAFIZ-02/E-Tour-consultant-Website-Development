// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TourPackage {
  id           String   @id @default(cuid())
  name         String
  category     String
  location     String
  description  String
  price        Int
  image        String
  includeGuide Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings Booking[]

  @@map("tour_packages")
}

model Transport {
  id          String   @id @default(cuid())
  type        String   // flight, bus, car-rental
  name        String
  from        String
  to          String
  price       Int
  date        DateTime?
  availableSeats Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("transports")
}

model Booking {
  id             String   @id @default(cuid())
  receiptId      String   @unique
  name           String
  email          String
  phone          String
  date           DateTime
  numberOfPeople Int
  serviceType    String   // package or transport
  serviceId      String
  notes          String?
  totalPrice     Int
  status         String   @default("pending") // pending, confirmed, cancelled
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  package       TourPackage? @relation(fields: [serviceId], references: [id])
  transport     Transport?   @relation(fields: [serviceId], references: [id])

  @@map("bookings")
}
